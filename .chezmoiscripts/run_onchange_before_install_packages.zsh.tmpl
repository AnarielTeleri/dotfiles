#!/bin/zsh

# Shell dotfiles may not be installed yet so we need to manually setup the
# Homebrew settings.
eval "$({{ .homebrew.binary }} shellenv)"

# Install all the brews and casks defined in .chezmoidata.
brew bundle --file=/dev/stdin <<EOF
{{ range .homebrew.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .homebrew.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
